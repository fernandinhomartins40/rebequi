# API Configuration
# Copy this file to .env.local or .env and configure based on your environment

# For Docker deployment (via Nginx reverse proxy)
VITE_API_URL=http://localhost/api

# For local development (backend running on port 3000)
# VITE_API_URL=http://localhost:3000/api

# For production
# VITE_API_URL=https://api.yourdom ain.com/api

# Authentication (if needed)
# VITE_AUTH_DOMAIN=
# VITE_AUTH_CLIENT_ID=

# Redirect para o painel do lojista apos login/alteracao de credenciais
# Pode ser uma URL externa (ex: https://admin.sualoja.com) ou uma rota interna (ex: /painel-lojista/painel)
VITE_MERCHANT_PANEL_URL=/painel-lojista/painel

# Other environment variables as needed
